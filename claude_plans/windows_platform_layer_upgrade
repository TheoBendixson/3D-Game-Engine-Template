### Step 2 — Extend `game_render_commands.h`

Add the Cave Factory 2D sprite types alongside the existing 3D types.
The combined struct will look like:

```c
// ---- 2D sprite types (from Cave Factory) ----
struct game_texture_draw_command { ... };          // per-sprite command
struct render_commands_array { ... };              // one Z-layer
#define BOTTOM_LAYER_COUNT 35
struct game_texture_draw_command_buffer { ... };   // 35 layers
struct game_texture_vertex { ... };                // quad vertex (2D, v2 Pos + v2 UV)
struct game_texture_vertex_buffer { ... };         // the 6-vertex quad
struct texture_draw_command_instance_uniforms { ... };
struct texture_draw_command_instance_buffer { ... };

// ---- existing 3D types (from Vario's Temple) ----
struct game_flat_color_vertex { ... };
struct game_texture_vertex_3d { ... };   // rename to avoid collision with 2D version
struct game_constants { ... };
struct mesh_instance { ... };
struct mesh_instance_buffer { ... };
struct game_vertex_buffer { ... };
struct game_indexed_vertex_buffer { ... };
struct push_buffer { ... };

struct game_render_commands
{
    // shared
    s32 ViewportWidth, ViewportHeight;
    clear_color ClearColor;

    // 2D sprite pipeline
    memory_arena DrawCommandsArena;
    game_texture_draw_command_buffer DrawCommandsBuffer;
    game_texture_vertex_buffer SpriteVertexBuffer;
    texture_draw_command_instance_buffer InstanceBuffer;
    game_texture_description SupportedTextureTypes[MAX_SUPPORTED_TEXTURE_TYPES];
    ...

    // 3D mesh pipeline (existing)
    game_vertex_buffer FlatColorVertexBuffer;
    game_vertex_buffer TextureVertexBuffer;
    game_indexed_vertex_buffer LoadedModelVertexBuffer;
    mesh_instance_buffer FlatColorMeshInstances;
    mesh_instance_buffer TexturedMeshInstances;
    mesh_instance_buffer LoadedModelMeshInstances;
    push_buffer ColoredCubePushBuffer;
    push_buffer TexturedCubePushBuffer;
};
```

Note: the name `game_texture_vertex` is used in both codebases for different
structs (2D in CF, 3D in VT). Rename Vario's 3D version to
`game_texture_vertex_3d` everywhere it is referenced.

